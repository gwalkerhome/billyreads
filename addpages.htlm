<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Billy Reads | Añadir Páginas</title>
    <style>
        :root {
            --mc-font: 'Arial Black', Gadget, sans-serif;
            --accent-blue: #4a90e2;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: #f0f4f8;
            margin: 0; padding: 20px;
            display: flex; flex-direction: column; align-items: center;
        }

        .container {
            width: 100%; max-width: 500px;
            background: white; border-radius: 20px;
            padding: 30px; box-shadow: 0 10px 25px rgba(0,0,0,0.05);
            box-sizing: border-box;
        }

        h1 { font-family: var(--mc-font); color: #2c3e50; text-align: center; margin-top: 0; font-size: 1.2rem; }
        #book-title-display { text-align: center; color: var(--accent-blue); font-weight: bold; margin-bottom: 20px; }

        .input-group { margin-bottom: 20px; }
        label { display: block; font-weight: bold; margin-bottom: 8px; color: #34495e; font-size: 0.9rem; }
        
        input[type="file"] {
            width: 100%; padding: 12px;
            border: 2px solid #edf2f7; border-radius: 12px;
            box-sizing: border-box; font-size: 1rem;
        }

        .btn-upload {
            width: 100%; padding: 18px;
            background: var(--accent-blue); color: white;
            border: none; border-radius: 15px;
            font-family: var(--mc-font); font-size: 1.1rem;
            cursor: pointer;
        }
        .btn-upload:disabled { background: #cbd5e0; }

        #status {
            margin-top: 15px; text-align: center;
            font-size: 0.85rem; color: #7f8c8d;
            min-height: 1.5em;
        }

        .nav-footer { margin-top: 20px; width: 100%; max-width: 500px; }
        #btn-back {
            width: 100%; padding: 12px; border: none; border-radius: 12px;
            background: #eee; color: #666; font-family: var(--mc-font);
            cursor: pointer;
        }
    </style>
</head>
<body>

    <div class="container">
        <h1>AÑADIR PÁGINAS</h1>
        <div id="book-title-display">---</div>
        
        <div class="input-group">
            <label>Seleccionar Imágenes (puedes elegir varias)</label>
            <input type="file" id="pageFiles" accept="image/*" multiple>
        </div>

        <button id="uploadBtn" class="btn-upload">SUBIR PÁGINAS</button>
        <div id="status"></div>
    </div>

    <div class="nav-footer">
        <button id="btn-back" onclick="location.href='pages.html'">VOLVER</button>
    </div>

    <script type="module">
        import { db, storage, collection, doc, setDoc, ref, uploadBytes, getDownloadURL } from "./firebase-bridge.js";

        const bookid = localStorage.getItem('current_book_id');
        const booktitle = localStorage.getItem('current_book_title');
        
        if (!bookid) location.href = 'magicbook.html';
        document.getElementById('book-title-display').innerText = booktitle;

        const uploadBtn = document.getElementById('uploadBtn');
        const status = document.getElementById('status');

        async function uploadPages() {
            const files = document.getElementById('pageFiles').files;
            if (files.length === 0) {
                alert("Por favor, selecciona al menos una imagen.");
                return;
            }

            uploadBtn.disabled = true;
            status.style.color = "#7f8c8d";

            try {
                for (let i = 0; i < files.length; i++) {
                    const file = files[i];
                    const pagenumber = i + 1; // Basic ordering logic
                    const pageid = `page_${Date.now()}_${i}`;
                    
                    status.innerText = `Subiendo página ${pagenumber} de ${files.length}...`;

                    // 1. Upload to Storage: books/[bookid]/pages/[filename]
                    const storagePath = `books/${bookid}/pages/${pageid}`;
                    const pageRef = ref(storage, storagePath);
                    const snap = await uploadBytes(pageRef, file);
                    const url = await getDownloadURL(snap.ref);

                    // 2. Save to Firestore Sub-collection: books/[bookid]/pages/[docid]
                    const firestorePath = `books/${bookid}/pages`;
                    const pageDocRef = doc(collection(db, firestorePath));
                    
                    await setDoc(pageDocRef, {
                        imageurl: url,
                        pagenumber: pagenumber,
                        uploadedat: Date.now()
                    });
                }

                status.style.color = "green";
                status.innerText = "✅ ¡Todas las páginas se han subido!";
                setTimeout(() => location.href = 'pages.html', 1500);

            } catch (error) {
                console.error("Upload error:", error);
                status.style.color = "red";
                status.innerText = "❌ Error: " + error.message;
                uploadBtn.disabled = false;
            }
        }

        uploadBtn.onclick = uploadPages;
    </script>
</body>
</html>
